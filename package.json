{
  "name": "video-editor",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "24.12.0",
    "pnpm": "10.32.1"
  },
  "scripts": {
    "dev": "pnpm --recursive --if-present dev",
    "build": "cargo build --workspace --locked && pnpm --recursive --if-present build",
    "test": "cargo test --workspace --locked && pnpm --recursive --if-present test"
  }
}
