{
  "name": "video-editor",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "24.12.0",
    "pnpm": "10.32.1"
  },
  "scripts": {
    "dev": "pnpm --recursive --if-present dev",
    "build:rust": "cargo check --workspace --locked && cargo build --workspace --locked",
    "build:native": "pnpm --filter @video-editor/desktop build:native",
    "build:desktop": "pnpm --filter @video-editor/desktop build",
    "build": "pnpm run build:rust && pnpm run build:desktop",
    "test:rust": "cargo fmt --all --check && cargo check --workspace --locked && cargo test --workspace --locked",
    "test:schema": "cargo test -p draft_model schema -- --nocapture",
    "test:runtime": "cargo test -p media_runtime discovery -- --nocapture",
    "test:bindings": "cargo test -p bindings_node -- --nocapture",
    "test:desktop": "pnpm --filter @video-editor/desktop test",
    "test:render-smoke": "cargo test -p testkit render_smoke -- --nocapture",
    "test:contracts": "git diff --exit-code schemas apps/desktop-electron/src/generated",
    "test": "pnpm run test:rust && pnpm run test:schema && pnpm run test:runtime && pnpm run test:bindings && pnpm run test:desktop && pnpm run test:render-smoke && pnpm run test:contracts"
  }
}
