{
  "$defs": {
    "CommandName": {
      "description": "Command names supported by the Rust contract.",
      "enum": [
        "ping",
        "version",
        "probeMediaRuntime",
        "importMaterial",
        "listMaterials",
        "listMissingMaterials"
      ],
      "type": "string"
    },
    "CommandPayload": {
      "description": "Command payloads.",
      "oneOf": [
        {
          "additionalProperties": false,
          "description": "Payload accepted by the Phase 1 `ping` command.",
          "properties": {
            "kind": {
              "const": "ping",
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "description": "Payload accepted by the Phase 1 `version` command.",
          "properties": {
            "kind": {
              "const": "version",
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "description": "Payload accepted by the Phase 1 non-editing runtime probe command.",
          "properties": {
            "kind": {
              "const": "probeMediaRuntime",
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "description": "Payload accepted by the Phase 2 material import command.",
          "properties": {
            "bundlePath": {
              "type": "string"
            },
            "displayName": {
              "type": [
                "string",
                "null"
              ]
            },
            "draft": {
              "$ref": "#/$defs/Draft"
            },
            "kind": {
              "const": "importMaterial",
              "type": "string"
            },
            "materialId": {
              "anyOf": [
                {
                  "$ref": "#/$defs/MaterialId"
                },
                {
                  "type": "null"
                }
              ]
            },
            "materialKindHint": {
              "anyOf": [
                {
                  "$ref": "#/$defs/MaterialKind"
                },
                {
                  "type": "null"
                }
              ]
            },
            "materialPath": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "draft",
            "bundlePath",
            "materialPath"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "description": "Payload accepted by the Phase 2 material list command.",
          "properties": {
            "draft": {
              "$ref": "#/$defs/Draft"
            },
            "kind": {
              "const": "listMaterials",
              "type": "string"
            }
          },
          "required": [
            "kind",
            "draft"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "description": "Payload accepted by the Phase 2 missing-material diagnostic command.",
          "properties": {
            "bundlePath": {
              "type": "string"
            },
            "draft": {
              "$ref": "#/$defs/Draft"
            },
            "kind": {
              "const": "listMissingMaterials",
              "type": "string"
            }
          },
          "required": [
            "kind",
            "draft",
            "bundlePath"
          ],
          "type": "object"
        }
      ]
    },
    "Draft": {
      "additionalProperties": false,
      "properties": {
        "draftId": {
          "$ref": "#/$defs/DraftId"
        },
        "materials": {
          "items": {
            "$ref": "#/$defs/Material"
          },
          "type": "array"
        },
        "metadata": {
          "$ref": "#/$defs/DraftMetadata"
        },
        "schemaVersion": {
          "$ref": "#/$defs/DraftSchemaVersion"
        },
        "tracks": {
          "items": {
            "$ref": "#/$defs/Track"
          },
          "type": "array"
        }
      },
      "required": [
        "schemaVersion",
        "draftId",
        "metadata",
        "materials",
        "tracks"
      ],
      "type": "object"
    },
    "DraftId": {
      "type": "string"
    },
    "DraftMetadata": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "DraftSchemaVersion": {
      "const": 1,
      "type": "integer"
    },
    "Filter": {
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string"
        },
        "parameters": {
          "additionalProperties": {
            "type": "string"
          },
          "type": "object"
        }
      },
      "required": [
        "name",
        "parameters"
      ],
      "type": "object"
    },
    "Keyframe": {
      "additionalProperties": false,
      "properties": {
        "at": {
          "$ref": "#/$defs/Microseconds"
        },
        "property": {
          "type": "string"
        },
        "value": {
          "type": "string"
        }
      },
      "required": [
        "at",
        "property",
        "value"
      ],
      "type": "object"
    },
    "MainTrackMagnet": {
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "required": [
        "enabled"
      ],
      "type": "object"
    },
    "Material": {
      "additionalProperties": false,
      "properties": {
        "displayName": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/MaterialKind"
        },
        "materialId": {
          "$ref": "#/$defs/MaterialId"
        },
        "metadata": {
          "$ref": "#/$defs/MaterialMetadata"
        },
        "status": {
          "$ref": "#/$defs/MaterialStatus"
        },
        "uri": {
          "type": "string"
        }
      },
      "required": [
        "materialId",
        "kind",
        "uri",
        "displayName",
        "metadata",
        "status"
      ],
      "type": "object"
    },
    "MaterialId": {
      "type": "string"
    },
    "MaterialKind": {
      "enum": [
        "video",
        "image",
        "audio",
        "text",
        "sticker"
      ],
      "type": "string"
    },
    "MaterialMetadata": {
      "additionalProperties": false,
      "properties": {
        "audioChannels": {
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "audioSampleRate": {
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "duration": {
          "anyOf": [
            {
              "$ref": "#/$defs/Microseconds"
            },
            {
              "type": "null"
            }
          ]
        },
        "frameRate": {
          "anyOf": [
            {
              "$ref": "#/$defs/RationalFrameRate"
            },
            {
              "type": "null"
            }
          ]
        },
        "hasAudio": {
          "type": "boolean"
        },
        "hasVideo": {
          "type": "boolean"
        },
        "height": {
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "probeError": {
          "type": [
            "string",
            "null"
          ]
        },
        "width": {
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "required": [
        "hasVideo",
        "hasAudio"
      ],
      "type": "object"
    },
    "MaterialStatus": {
      "enum": [
        "available",
        "missing",
        "probeFailed"
      ],
      "type": "string"
    },
    "Microseconds": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
    },
    "RationalFrameRate": {
      "additionalProperties": false,
      "properties": {
        "denominator": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "numerator": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "numerator",
        "denominator"
      ],
      "type": "object"
    },
    "Segment": {
      "additionalProperties": false,
      "properties": {
        "filters": {
          "items": {
            "$ref": "#/$defs/Filter"
          },
          "type": "array"
        },
        "keyframes": {
          "items": {
            "$ref": "#/$defs/Keyframe"
          },
          "type": "array"
        },
        "mainTrackMagnet": {
          "$ref": "#/$defs/MainTrackMagnet"
        },
        "materialId": {
          "$ref": "#/$defs/MaterialId"
        },
        "segmentId": {
          "$ref": "#/$defs/SegmentId"
        },
        "sourceTimerange": {
          "$ref": "#/$defs/SourceTimerange"
        },
        "targetTimerange": {
          "$ref": "#/$defs/TargetTimerange"
        },
        "transition": {
          "anyOf": [
            {
              "$ref": "#/$defs/Transition"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "segmentId",
        "materialId",
        "sourceTimerange",
        "targetTimerange",
        "mainTrackMagnet",
        "keyframes",
        "filters"
      ],
      "type": "object"
    },
    "SegmentId": {
      "type": "string"
    },
    "SourceTimerange": {
      "additionalProperties": false,
      "properties": {
        "duration": {
          "$ref": "#/$defs/Microseconds"
        },
        "start": {
          "$ref": "#/$defs/Microseconds"
        }
      },
      "required": [
        "start",
        "duration"
      ],
      "type": "object"
    },
    "TargetTimerange": {
      "additionalProperties": false,
      "properties": {
        "duration": {
          "$ref": "#/$defs/Microseconds"
        },
        "start": {
          "$ref": "#/$defs/Microseconds"
        }
      },
      "required": [
        "start",
        "duration"
      ],
      "type": "object"
    },
    "Track": {
      "additionalProperties": false,
      "properties": {
        "kind": {
          "$ref": "#/$defs/TrackKind"
        },
        "locked": {
          "type": "boolean"
        },
        "muted": {
          "type": "boolean"
        },
        "name": {
          "type": "string"
        },
        "segments": {
          "items": {
            "$ref": "#/$defs/Segment"
          },
          "type": "array"
        },
        "trackId": {
          "$ref": "#/$defs/TrackId"
        }
      },
      "required": [
        "trackId",
        "kind",
        "name",
        "muted",
        "locked",
        "segments"
      ],
      "type": "object"
    },
    "TrackId": {
      "type": "string"
    },
    "TrackKind": {
      "enum": [
        "video",
        "audio",
        "text",
        "sticker",
        "filter"
      ],
      "type": "string"
    },
    "Transition": {
      "additionalProperties": false,
      "properties": {
        "duration": {
          "$ref": "#/$defs/Microseconds"
        },
        "name": {
          "type": "string"
        }
      },
      "required": [
        "name",
        "duration"
      ],
      "type": "object"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Rust-owned command envelope accepted by the Electron binding boundary.",
  "oneOf": [
    {
      "properties": {
        "command": {
          "const": "ping"
        },
        "payload": {
          "properties": {
            "kind": {
              "const": "ping"
            }
          },
          "required": [
            "kind"
          ]
        }
      }
    },
    {
      "properties": {
        "command": {
          "const": "version"
        },
        "payload": {
          "properties": {
            "kind": {
              "const": "version"
            }
          },
          "required": [
            "kind"
          ]
        }
      }
    },
    {
      "properties": {
        "command": {
          "const": "probeMediaRuntime"
        },
        "payload": {
          "properties": {
            "kind": {
              "const": "probeMediaRuntime"
            }
          },
          "required": [
            "kind"
          ]
        }
      }
    },
    {
      "properties": {
        "command": {
          "const": "importMaterial"
        },
        "payload": {
          "properties": {
            "kind": {
              "const": "importMaterial"
            }
          },
          "required": [
            "kind"
          ]
        }
      }
    },
    {
      "properties": {
        "command": {
          "const": "listMaterials"
        },
        "payload": {
          "properties": {
            "kind": {
              "const": "listMaterials"
            }
          },
          "required": [
            "kind"
          ]
        }
      }
    },
    {
      "properties": {
        "command": {
          "const": "listMissingMaterials"
        },
        "payload": {
          "properties": {
            "kind": {
              "const": "listMissingMaterials"
            }
          },
          "required": [
            "kind"
          ]
        }
      }
    }
  ],
  "properties": {
    "command": {
      "$ref": "#/$defs/CommandName"
    },
    "payload": {
      "$ref": "#/$defs/CommandPayload"
    },
    "requestId": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "command",
    "payload"
  ],
  "title": "CommandEnvelope",
  "type": "object"
}
