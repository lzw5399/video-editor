    "CommandState": {
      "additionalProperties": false,
      "description": "Session-only command state passed through Electron as opaque Rust-owned data.",
      "properties": {
        "maxHistoryEntries": {
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "redoStack": {
          "items": {
            "$ref": "#/$defs/CommandHistorySnapshot"
          },
          "type": "array"
        },
        "snapping": {
          "$ref": "#/$defs/SnappingSettings"
        },
        "undoStack": {
          "items": {
            "$ref": "#/$defs/CommandHistorySnapshot"
          },
          "type": "array"
        }
      },
      "required": [
        "undoStack",
        "redoStack",
        "maxHistoryEntries",
        "snapping"
      ],
      "type": "object"
    },
    "DeleteSegmentCommandPayload": {
      "additionalProperties": false,
