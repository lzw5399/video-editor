      "type": "string"
    },
    "MaterialKind": {
      "enum": [
        "video",
        "image",
        "audio",
        "text",
        "sticker"
      ],
      "type": "string"
    },
    "MaterialMetadata": {
      "additionalProperties": false,
      "properties": {
        "audioChannels": {
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "audioSampleRate": {
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "duration": {
          "anyOf": [
            {
              "$ref": "#/$defs/Microseconds"
            },
            {
              "type": "null"
            }
          ]
        },
        "frameRate": {
          "anyOf": [
            {
              "$ref": "#/$defs/RationalFrameRate"
            },
            {
              "type": "null"
            }
          ]
        },
        "hasAudio": {
          "type": "boolean"
        },
        "hasVideo": {
          "type": "boolean"
        },
        "height": {
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "probeError": {
          "type": [
            "string",
            "null"
          ]
        },
        "width": {
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        }
      },
      "required": [
        "hasVideo",
        "hasAudio"
      ],
      "type": "object"
    },
    "MaterialStatus": {
      "enum": [
        "available",
        "missing",
        "probeFailed"
      ],
      "type": "string"
    },
    "Microseconds": {
      "format": "uint64",
      "minimum": 0,
      "type": "integer"
