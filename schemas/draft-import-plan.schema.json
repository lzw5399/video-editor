{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DraftImportPlan",
  "type": "object",
  "properties": {
    "canvasConfig": {
      "$ref": "#/$defs/DraftCanvasConfig"
    },
    "draftId": {
      "$ref": "#/$defs/DraftId"
    },
    "draftName": {
      "type": "string"
    },
    "importId": {
      "type": "string"
    },
    "materials": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ImportMaterialPlan"
      }
    },
    "schemaVersion": {
      "$ref": "#/$defs/DraftImportPlanSchemaVersion"
    },
    "tracks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/ImportTrackPlan"
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "importId",
    "draftId",
    "draftName",
    "canvasConfig",
    "materials",
    "tracks"
  ],
  "$defs": {
    "AudioEffectSlot": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "kind": {
          "$ref": "#/$defs/AudioEffectSlotKind"
        },
        "slotId": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "slotId",
        "kind",
        "enabled"
      ]
    },
    "AudioEffectSlotKind": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "externalRef": {
              "type": [
                "string",
                "null"
              ]
            },
            "kind": {
              "type": "string",
              "const": "unsupported"
            },
            "name": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "name"
          ]
        }
      ]
    },
    "AudioFade": {
      "type": "object",
      "properties": {
        "duration": {
          "$ref": "#/$defs/Microseconds"
        }
      },
      "additionalProperties": false,
      "required": [
        "duration"
      ]
    },
    "AudioPanBalance": {
      "type": "integer",
      "format": "int32",
      "maximum": 1000,
      "minimum": -1000
    },
    "CanvasAdaptationPolicy": {
      "type": "string",
      "enum": [
        "auto",
        "manual"
      ]
    },
    "CanvasAspectRatio": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "preset"
            },
            "preset": {
              "$ref": "#/$defs/CanvasAspectRatioPreset"
            }
          },
          "required": [
            "kind",
            "preset"
          ]
        },
        {
          "type": "object",
          "properties": {
            "denominator": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0
            },
            "kind": {
              "type": "string",
              "const": "custom"
            },
            "numerator": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0
            }
          },
          "required": [
            "kind",
            "numerator",
            "denominator"
          ]
        }
      ]
    },
    "CanvasAspectRatioPreset": {
      "type": "string",
      "enum": [
        "ratio16x9",
        "ratio9x16",
        "ratio1x1",
        "ratio4x3",
        "ratio3x4"
      ]
    },
    "CanvasBackground": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "black"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "color": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "const": "solidColor"
            }
          },
          "required": [
            "kind",
            "color"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "blurFill"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "image"
            },
            "materialId": {
              "anyOf": [
                {
                  "$ref": "#/$defs/MaterialId"
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "required": [
            "kind"
          ]
        }
      ]
    },
    "DraftCanvasConfig": {
      "type": "object",
      "properties": {
        "adaptationPolicy": {
          "$ref": "#/$defs/CanvasAdaptationPolicy",
          "default": "auto"
        },
        "aspectRatio": {
          "$ref": "#/$defs/CanvasAspectRatio"
        },
        "background": {
          "$ref": "#/$defs/CanvasBackground"
        },
        "frameRate": {
          "$ref": "#/$defs/RationalFrameRate"
        },
        "height": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "width": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "aspectRatio",
        "width",
        "height",
        "frameRate",
        "background"
      ]
    },
    "DraftId": {
      "type": "string"
    },
    "DraftImportPlanSchemaVersion": {
      "type": "integer",
      "format": "uint32",
      "minimum": 0
    },
    "Filter": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "parameters": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "name",
        "parameters"
      ]
    },
    "ImportMaterialPlan": {
      "type": "object",
      "properties": {
        "material": {
          "$ref": "#/$defs/Material"
        }
      },
      "additionalProperties": false,
      "required": [
        "material"
      ]
    },
    "ImportTrackPlan": {
      "type": "object",
      "properties": {
        "track": {
          "$ref": "#/$defs/Track"
        },
        "zOrder": {
          "type": "integer",
          "format": "int32"
        }
      },
      "additionalProperties": false,
      "required": [
        "zOrder",
        "track"
      ]
    },
    "Keyframe": {
      "type": "object",
      "properties": {
        "at": {
          "$ref": "#/$defs/Microseconds"
        },
        "easing": {
          "$ref": "#/$defs/KeyframeEasing"
        },
        "interpolation": {
          "$ref": "#/$defs/KeyframeInterpolation"
        },
        "property": {
          "$ref": "#/$defs/KeyframeProperty"
        },
        "value": {
          "$ref": "#/$defs/KeyframeValue"
        }
      },
      "additionalProperties": false,
      "required": [
        "at",
        "property",
        "value",
        "interpolation",
        "easing"
      ]
    },
    "KeyframeEasing": {
      "type": "string",
      "enum": [
        "none",
        "easeIn",
        "easeOut",
        "easeInOut"
      ]
    },
    "KeyframeInterpolation": {
      "type": "string",
      "enum": [
        "hold",
        "linear"
      ]
    },
    "KeyframeProperty": {
      "type": "string",
      "enum": [
        "visualPositionX",
        "visualPositionY",
        "visualScaleX",
        "visualScaleY",
        "visualRotation",
        "visualOpacity",
        "textFontSize",
        "textColor",
        "textLineHeight",
        "textLetterSpacing",
        "textLayoutX",
        "textLayoutY",
        "textLayoutWidth",
        "textLayoutHeight",
        "volume",
        "stickerPositionX",
        "stickerPositionY",
        "stickerScaleX",
        "stickerScaleY",
        "filterParameterUnsupported"
      ]
    },
    "KeyframeValue": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "int"
            },
            "value": {
              "type": "integer",
              "format": "int32"
            }
          },
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "uint"
            },
            "value": {
              "type": "integer",
              "format": "uint32",
              "minimum": 0
            }
          },
          "required": [
            "kind",
            "value"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "color"
            },
            "value": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "value"
          ]
        }
      ]
    },
    "MainTrackMagnet": {
      "type": "object",
      "properties": {
        "enabled": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "required": [
        "enabled"
      ]
    },
    "Material": {
      "type": "object",
      "properties": {
        "displayName": {
          "type": "string"
        },
        "kind": {
          "$ref": "#/$defs/MaterialKind"
        },
        "materialId": {
          "$ref": "#/$defs/MaterialId"
        },
        "metadata": {
          "$ref": "#/$defs/MaterialMetadata"
        },
        "status": {
          "$ref": "#/$defs/MaterialStatus"
        },
        "uri": {
          "type": "string"
        }
      },
      "additionalProperties": false,
      "required": [
        "materialId",
        "kind",
        "uri",
        "displayName",
        "metadata",
        "status"
      ]
    },
    "MaterialId": {
      "type": "string"
    },
    "MaterialKind": {
      "type": "string",
      "enum": [
        "video",
        "image",
        "audio",
        "text",
        "sticker"
      ]
    },
    "MaterialMetadata": {
      "type": "object",
      "properties": {
        "audioChannels": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint16",
          "maximum": 65535,
          "minimum": 0
        },
        "audioSampleRate": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "duration": {
          "anyOf": [
            {
              "$ref": "#/$defs/Microseconds"
            },
            {
              "type": "null"
            }
          ]
        },
        "frameRate": {
          "anyOf": [
            {
              "$ref": "#/$defs/RationalFrameRate"
            },
            {
              "type": "null"
            }
          ]
        },
        "hasAudio": {
          "type": "boolean"
        },
        "hasVideo": {
          "type": "boolean"
        },
        "height": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        },
        "probeError": {
          "type": [
            "string",
            "null"
          ]
        },
        "width": {
          "type": [
            "integer",
            "null"
          ],
          "format": "uint32",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "hasVideo",
        "hasAudio"
      ]
    },
    "MaterialStatus": {
      "type": "string",
      "enum": [
        "available",
        "missing",
        "probeFailed"
      ]
    },
    "Microseconds": {
      "type": "integer",
      "format": "uint64",
      "minimum": 0
    },
    "RationalFrameRate": {
      "type": "object",
      "properties": {
        "denominator": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "numerator": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "numerator",
        "denominator"
      ]
    },
    "Segment": {
      "type": "object",
      "properties": {
        "audio": {
          "$ref": "#/$defs/SegmentAudio",
          "default": {
            "effectSlots": [],
            "fadeInDuration": {
              "duration": 0
            },
            "fadeOutDuration": {
              "duration": 0
            },
            "gainMillis": 1000,
            "panBalanceMillis": 0
          }
        },
        "filters": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Filter"
          }
        },
        "keyframes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Keyframe"
          }
        },
        "mainTrackMagnet": {
          "$ref": "#/$defs/MainTrackMagnet"
        },
        "materialId": {
          "$ref": "#/$defs/MaterialId"
        },
        "segmentId": {
          "$ref": "#/$defs/SegmentId"
        },
        "sourceTimerange": {
          "$ref": "#/$defs/SourceTimerange"
        },
        "targetTimerange": {
          "$ref": "#/$defs/TargetTimerange"
        },
        "text": {
          "anyOf": [
            {
              "$ref": "#/$defs/TextSegment"
            },
            {
              "type": "null"
            }
          ]
        },
        "transition": {
          "anyOf": [
            {
              "$ref": "#/$defs/Transition"
            },
            {
              "type": "null"
            }
          ]
        },
        "visual": {
          "$ref": "#/$defs/SegmentVisual",
          "default": {
            "backgroundFilling": {
              "kind": "none"
            },
            "blendMode": {
              "kind": "normal"
            },
            "fitMode": "fit",
            "mask": {
              "kind": "none"
            },
            "transform": {
              "anchor": {
                "xMillis": 500,
                "yMillis": 500
              },
              "crop": {
                "bottomMillis": 0,
                "leftMillis": 0,
                "rightMillis": 0,
                "topMillis": 0
              },
              "opacity": {
                "valueMillis": 1000
              },
              "position": {
                "x": 0,
                "y": 0
              },
              "rotation": {
                "degrees": 0
              },
              "scale": {
                "xMillis": 1000,
                "yMillis": 1000
              }
            },
            "visible": true
          }
        },
        "volume": {
          "$ref": "#/$defs/SegmentVolume",
          "default": {
            "levelMillis": 1000
          }
        }
      },
      "additionalProperties": false,
      "required": [
        "segmentId",
        "materialId",
        "sourceTimerange",
        "targetTimerange",
        "mainTrackMagnet",
        "keyframes",
        "filters"
      ]
    },
    "SegmentAnchor": {
      "type": "object",
      "properties": {
        "xMillis": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "yMillis": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "xMillis",
        "yMillis"
      ]
    },
    "SegmentAudio": {
      "type": "object",
      "properties": {
        "effectSlots": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/AudioEffectSlot"
          }
        },
        "fadeInDuration": {
          "$ref": "#/$defs/AudioFade"
        },
        "fadeOutDuration": {
          "$ref": "#/$defs/AudioFade"
        },
        "gainMillis": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "panBalanceMillis": {
          "$ref": "#/$defs/AudioPanBalance"
        }
      },
      "additionalProperties": false,
      "required": [
        "gainMillis",
        "panBalanceMillis",
        "fadeInDuration",
        "fadeOutDuration",
        "effectSlots"
      ]
    },
    "SegmentBackgroundFilling": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "none"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "black"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "color": {
              "type": "string"
            },
            "kind": {
              "type": "string",
              "const": "solidColor"
            }
          },
          "required": [
            "kind",
            "color"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "blur"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "image"
            },
            "materialId": {
              "anyOf": [
                {
                  "$ref": "#/$defs/MaterialId"
                },
                {
                  "type": "null"
                }
              ]
            }
          },
          "required": [
            "kind"
          ]
        }
      ]
    },
    "SegmentBlendMode": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "normal"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "unsupported"
            },
            "name": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "name"
          ]
        }
      ]
    },
    "SegmentCrop": {
      "type": "object",
      "properties": {
        "bottomMillis": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "leftMillis": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "rightMillis": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "topMillis": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "leftMillis",
        "rightMillis",
        "topMillis",
        "bottomMillis"
      ]
    },
    "SegmentFitMode": {
      "type": "string",
      "enum": [
        "fit",
        "fill",
        "stretch"
      ]
    },
    "SegmentId": {
      "type": "string"
    },
    "SegmentMask": {
      "oneOf": [
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "none"
            }
          },
          "required": [
            "kind"
          ]
        },
        {
          "type": "object",
          "properties": {
            "kind": {
              "type": "string",
              "const": "unsupported"
            },
            "name": {
              "type": "string"
            }
          },
          "required": [
            "kind",
            "name"
          ]
        }
      ]
    },
    "SegmentOpacity": {
      "type": "object",
      "properties": {
        "valueMillis": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "valueMillis"
      ]
    },
    "SegmentPosition": {
      "type": "object",
      "properties": {
        "x": {
          "type": "integer",
          "format": "int32"
        },
        "y": {
          "type": "integer",
          "format": "int32"
        }
      },
      "additionalProperties": false,
      "required": [
        "x",
        "y"
      ]
    },
    "SegmentRotation": {
      "type": "object",
      "properties": {
        "degrees": {
          "type": "integer",
          "format": "int32"
        }
      },
      "additionalProperties": false,
      "required": [
        "degrees"
      ]
    },
    "SegmentScale": {
      "type": "object",
      "properties": {
        "xMillis": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        },
        "yMillis": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "xMillis",
        "yMillis"
      ]
    },
    "SegmentTransform": {
      "type": "object",
      "properties": {
        "anchor": {
          "$ref": "#/$defs/SegmentAnchor"
        },
        "crop": {
          "$ref": "#/$defs/SegmentCrop"
        },
        "opacity": {
          "$ref": "#/$defs/SegmentOpacity"
        },
        "position": {
          "$ref": "#/$defs/SegmentPosition"
        },
        "rotation": {
          "$ref": "#/$defs/SegmentRotation"
        },
        "scale": {
          "$ref": "#/$defs/SegmentScale"
        }
      },
      "additionalProperties": false,
      "required": [
        "position",
        "scale",
        "rotation",
        "opacity",
        "crop",
        "anchor"
      ]
    },
    "SegmentVisual": {
      "type": "object",
      "properties": {
        "backgroundFilling": {
          "$ref": "#/$defs/SegmentBackgroundFilling"
        },
        "blendMode": {
          "$ref": "#/$defs/SegmentBlendMode"
        },
        "fitMode": {
          "$ref": "#/$defs/SegmentFitMode"
        },
        "mask": {
          "$ref": "#/$defs/SegmentMask"
        },
        "transform": {
          "$ref": "#/$defs/SegmentTransform"
        },
        "visible": {
          "type": "boolean"
        }
      },
      "additionalProperties": false,
      "required": [
        "visible",
        "transform",
        "fitMode",
        "backgroundFilling",
        "blendMode",
        "mask"
      ]
    },
    "SegmentVolume": {
      "type": "object",
      "properties": {
        "levelMillis": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0
        }
      },
      "additionalProperties": false,
      "required": [
        "levelMillis"
      ]
    },
    "SourceTimerange": {
      "type": "object",
      "properties": {
        "duration": {
          "$ref": "#/$defs/Microseconds"
        },
        "start": {
          "$ref": "#/$defs/Microseconds"
        }
      },
      "additionalProperties": false,
      "required": [
        "start",
        "duration"
      ]
    },
    "TargetTimerange": {
      "type": "object",
      "properties": {
        "duration": {
          "$ref": "#/$defs/Microseconds"
        },
        "start": {
          "$ref": "#/$defs/Microseconds"
        }
      },
      "additionalProperties": false,
      "required": [
        "start",
        "duration"
      ]
    },
    "TextAlignment": {
      "type": "string",
      "enum": [
